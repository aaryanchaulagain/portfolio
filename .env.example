# Database — replace with a real PostgreSQL URL (Neon, Supabase, Docker, etc.)
# Example: postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET=
ADMIN_EMAIL=
# bcrypt hash — escape every $ as \$ (Next.js expands $VAR in .env files)
# Generate with: npx tsx scripts/hash-password.ts "your-password"
ADMIN_PASSWORD_HASH=

# Email (Resend)
EMAIL_FROM="Portfolio <onboarding@resend.dev>"
RESEND_API_KEY=

# Public site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="[YOUR FULL NAME] | Software & Web Developer"

# Optional scheduling link included in approval emails
SCHEDULING_LINK=

# Optional Cloudflare Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
